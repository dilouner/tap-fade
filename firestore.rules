rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'client';

      allow read: if isOwner(userId) || isAdmin();

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && (
          request.resource.data.role == resource.data.role ||
          (resource.data.role == 'client' && request.resource.data.role == 'owner')
        )
        || (
          isAdmin()
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role in ['client', 'barber', 'owner', 'admin']
        );
    }

    match /barberShops/{barberShopId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.status == 'active');

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active';

      allow update: if (isShopOwner(barberShopId) || isAdmin())
        && request.resource.data.ownerId == resource.data.ownerId;

      match /services/{serviceId} {
        allow read: if isAdmin() || (isSignedIn() && isActiveShop(barberShopId));
        allow create, update: if isShopOwner(barberShopId) || isAdmin();
      }

      match /barbers/{barberId} {
        allow read: if isAdmin() || (isSignedIn() && isActiveShop(barberShopId));
        allow create, update: if isShopOwner(barberShopId) || isAdmin();
      }

      match /availability/{availabilityId} {
        allow read: if isAdmin() || (isSignedIn() && isActiveShop(barberShopId));
        allow create, update: if isShopOwner(barberShopId) || isAdmin();
      }
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn()
        && (
          isAdmin() ||
          resource.data.clientId == request.auth.uid ||
          isShopOwner(resource.data.barberShopId) ||
          isAssignedBarber(resource.data.barberShopId, resource.data.barberId)
        );

      allow create: if isSignedIn()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == 'pending'
        && isActiveShop(request.resource.data.barberShopId);

      allow update: if isSignedIn()
        && (
          isAdmin() ||
          canClientUpdateAppointment() ||
          canOperatorUpdateAppointment()
        );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function shopPath(barberShopId) {
      return /databases/$(database)/documents/barberShops/$(barberShopId);
    }

    function isActiveShop(barberShopId) {
      return exists(shopPath(barberShopId)) && get(shopPath(barberShopId)).data.status == 'active';
    }

    function isShopOwner(barberShopId) {
      return isSignedIn()
        && exists(shopPath(barberShopId))
        && get(shopPath(barberShopId)).data.ownerId == request.auth.uid;
    }

    function isAssignedBarber(barberShopId, barberId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/barberShops/$(barberShopId)/barbers/$(barberId))
        && get(/databases/$(database)/documents/barberShops/$(barberShopId)/barbers/$(barberId)).data.userId == request.auth.uid;
    }

    function canClientUpdateAppointment() {
      return resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.status in ['pending', 'cancelled']
        && resource.data.status in ['pending', 'confirmed'];
    }

    function canOperatorUpdateAppointment() {
      return (isShopOwner(resource.data.barberShopId) || isAssignedBarber(resource.data.barberShopId, resource.data.barberId))
        && request.resource.data.barberShopId == resource.data.barberShopId
        && request.resource.data.status in ['confirmed', 'rejected', 'cancelled', 'completed'];
    }
  }
}
